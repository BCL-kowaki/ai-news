// AI秘書（秘書エージェント） — DBスキーマ
// Neon PostgreSQL を使用。
// - DATABASE_URL: 実行時に使う接続文字列（Neonの「Pooled connection」= -pooler 付き）
// - DIRECT_URL:   マイグレーション用の直接接続（Neonの「Direct connection」）
//   ※ サーバーレスは同時起動が多くDB接続が枯渇するため、実行時はプール経由が必須。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// RSSソース（TechCrunch AI 等）。src/lib/sources.ts の定義から自動で同期される。
model Source {
  id          String    @id @default(cuid())
  name        String
  url         String    @unique // RSSフィードのURL
  category    String? // "AI全般" / "研究" / "プロダクト" / "国内" / "論文" 等
  active      Boolean   @default(true)
  // 1回の収集で取り込む最大件数。arXivのような大量フィードが他を埋め尽くすのを防ぐ。
  // null＝無制限。新しい順にこの件数だけ取り込む。
  maxPerFetch Int?
  createdAt   DateTime  @default(now())
  articles    Article[]
}

/// 収集した記事。要約はせず、タイトルとURLのみ保持する。
model Article {
  id          String    @id @default(cuid())
  sourceId    String
  source      Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  title       String // 原文タイトル（そのまま保存）
  titleJa     String? // 日本語訳（DeepL）。日本語ソースや翻訳失敗時は null → 表示は原文にフォールバック
  contentText String? // RSSの本文抜粋（arXivは要旨）。オンデマンドの本文翻訳・要約の入力に使う
  url         String    @unique // 重複排除のキー
  publishedAt DateTime
  status      String    @default("pending") // pending（未送信） / sent（送信済み） / skipped（対象外）
  favoritedAt DateTime? // お気に入りに追加した日時（null=お気に入りでない）
  fetchedAt   DateTime  @default(now())
  sentAt      DateTime?

  // 配信ジョブは「pendingを古い順に取得」するため、この2列の複合インデックスが効く
  @@index([status, publishedAt])
}

/// Slack配信の記録（旧機能の名残。Slack配信廃止後は参照しないが、履歴保全のため残置）
model SendLog {
  id        String   @id @default(cuid())
  sentAt    DateTime @default(now())
  count     Int // その回で配信した記事数
  monthKey  String // "2026-07" 形式。月次の配信回数を数えるためのキー

  @@index([monthKey])
}

/// 連携したGoogleアカウント（会社用・個人用など）。フェーズ2で使用。
/// refresh_token は AES-256-GCM で暗号化して保存する（平文では絶対に持たない）。
model GoogleAccount {
  id              String   @id @default(cuid())
  label           String // 表示名（"会社" / "個人" など）
  email           String   @unique
  refreshTokenEnc String // 暗号化済み refresh_token
  scopes          String // 許可されたスコープ（スペース区切り）
  status          String   @default("active") // active（有効） / expired（要再連携）
  calendarIds     Json? // ダッシュボードに表示するカレンダーID配列（家族共用カレンダー含む選択）
  colorHex        String? // 予定表示の色分け
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// タスク（自前管理。Google Tasks等とは同期しない）
model Task {
  id          String    @id @default(cuid())
  title       String
  note        String? // 補足メモ（任意）
  due         DateTime? // 期限（任意）
  priority    Int       @default(1) // 0=低 / 1=中 / 2=高
  status      String    @default("open") // open（未完了） / done（完了）
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  // ダッシュボードは「未完了を優先度・期限順に取得」するため
  @@index([status, due])
}

/// メモ。kind で「突発メモ」と「よく使うメモ」を分ける。
model Memo {
  id          String           @id @default(cuid())
  kind        String // "quick"（突発メモ） / "pinned"（よく使うメモ）
  title       String? // よく使うメモの見出し（任意）
  body        String
  sortOrder   Int              @default(0) // よく使うメモの並び順（小さいほど上）
  folderId    String? // 所属フォルダ（null=未分類）
  folder      MemoFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  attachments MemoAttachment[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([kind, sortOrder])
  @@index([folderId])
}

/// メモのフォルダ（突発・よく使う共通のグルーピング）
model MemoFolder {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  memos     Memo[]
}

/// メモの添付ファイル（画像・動画・PDF・録音音声など。実体はVercel Blob）
model MemoAttachment {
  id        String   @id @default(cuid())
  memoId    String
  memo      Memo     @relation(fields: [memoId], references: [id], onDelete: Cascade)
  url       String // BlobのURL
  mime      String // image/png, video/mp4, application/pdf, audio/webm など
  name      String // 表示用ファイル名
  bytes     Int
  createdAt DateTime @default(now())

  @@index([memoId])
}

/// 会議の録音・文字起こし・レポート要約
model Meeting {
  id                   String   @id @default(cuid())
  title                String
  recordedAt           DateTime // 録音開始日時（アップロードの場合は取り込み日時）
  durationSec          Int? // 録音の長さ（秒）。取得できた場合のみ
  audioUrl             String? // Vercel Blob上の音声ファイルURL（文字起こし貼り付け取り込みの場合はnull）
  audioMime            String? // audio/webm, audio/mp4 など
  audioBytes           Int?
  status               String   @default("recorded") // recorded / transcribing / transcribed / summarizing / done / error
  transcript           String? // 文字起こし全文（Gemini）
  summaryMd            String? // レポート要約（Claude Haiku・Markdown）
  errorMsg             String? // 直近の処理エラー（画面表示用）
  calendarEventId      String? // Googleカレンダーに登録した予定のID（登録済みの印）
  calendarAccountEmail String? // どのアカウントのカレンダーに登録したか
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([recordedAt])
}

/// プッシュ通知の購読先（ブラウザ/スマホごとに1件）。ブリーフィング完成時などに送る。
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique // プッシュサービスのURL（購読の実体）
  p256dh    String // 暗号化用の公開鍵
  auth      String // 認証シークレット
  createdAt DateTime @default(now())
}

/// AIブリーフィング（朝の秘書メモ）。フェーズ3のcronが1日1件生成する。
model Briefing {
  id        String   @id @default(cuid())
  dateKey   String   @unique // "2026-07-17" 形式（JST基準の日付）
  content   String // 生成されたブリーフィング本文（Markdown）
  createdAt DateTime @default(now())
}
