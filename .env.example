# ------------------------------------------------------------
# 環境変数のテンプレート
# このファイルをコピーして .env を作り、値を埋める（.env はGitに載らない）
#   cp .env.example .env
# ------------------------------------------------------------

# Neon PostgreSQL の接続文字列
# DATABASE_URL: Neon管理画面の「Pooled connection」（ホスト名に -pooler が入っているもの）
# DIRECT_URL:   Neon管理画面の「Direct connection」（-pooler が入っていないもの。DB作成時に使う）
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ---- ログイン（NextAuth + Google） ----

# セッションCookieの暗号化キー（推測されない長い文字列。次のコマンドで生成できる）
#   openssl rand -base64 32
NEXTAUTH_SECRET=""

# アプリのURL（ローカルは http://localhost:3000、本番は https://xxx.vercel.app）
NEXTAUTH_URL="http://localhost:3000"

# Google CloudのOAuthクライアント（作成手順は docs/セットアップ手順.md）
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ログインを許可するGmailアドレス（カンマ区切りで複数可。ここに無いアカウントは全部拒否）
ALLOWED_EMAIL=""

# ---- 機能ごとのAPIキー ----

# DeepL API 無料版のキー（英語タイトルの日本語訳に使用）
# 未設定でも動作する（その場合は翻訳せず原文のまま表示）
DEEPL_API_KEY=""

# Anthropic APIキー（記事の「要約」ボタン・AIブリーフィングに使用。Claude Haiku）
# 未設定でも動作する（その場合は要約ボタンが「キーが必要」と表示するだけ）
ANTHROPIC_API_KEY=""

# Cronエンドポイントの認証キー（推測されない長い文字列。次のコマンドで生成できる）
#   openssl rand -hex 32
CRON_SECRET=""

# ---- フェーズ2で使用（Google連携のトークン暗号化キー） ----
# openssl rand -hex 32 で生成
# TOKEN_ENCRYPTION_KEY=""
