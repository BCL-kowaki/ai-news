# ------------------------------------------------------------
# 環境変数のテンプレート
# このファイルをコピーして .env を作り、値を埋める（.env はGitに載らない）
#   cp .env.example .env
# ------------------------------------------------------------

# Neon PostgreSQL の接続文字列
# DATABASE_URL: Neon管理画面の「Pooled connection」（ホスト名に -pooler が入っているもの）
# DIRECT_URL:   Neon管理画面の「Direct connection」（-pooler が入っていないもの。DB作成時に使う）
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Slack Incoming Webhook URL（Slack Appで発行。https://hooks.slack.com/services/... の形）
SLACK_WEBHOOK_URL=""

# Cronエンドポイントの認証キー（推測されない長い文字列。次のコマンドで生成できる）
#   openssl rand -hex 32
CRON_SECRET=""
